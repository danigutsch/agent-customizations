{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-customizations/plugin-bundle.schema.json",
  "title": "Agent Customizations Plugin Bundle",
  "description": "Neutral manifest for versioned .agents capability bundles.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "displayName",
    "description",
    "bundleType",
    "install",
    "contents",
    "documentation",
    "examples"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "bundleType": {
      "type": "string",
      "enum": [
        "capability-pack"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "maturity": {
      "type": "string",
      "enum": [
        "experimental",
        "beta",
        "stable"
      ]
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "layoutRoot"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "copy-files"
          ]
        },
        "layoutRoot": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "contents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "kind",
          "required"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "agent",
              "instruction",
              "skill",
              "reference",
              "prompt",
              "hook",
              "mcp",
              "workflow",
              "asset",
              "doc"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "documentation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changelog": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "optional"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "versionRange": {
            "type": "string"
          },
          "optional": {
            "type": "boolean"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "layoutRoots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
